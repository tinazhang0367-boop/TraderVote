# Legacy ThinkPHP backend (BFF proxy target)
NUXT_BACKEND_BASE_URL=https://tradervote.com

# Database. SQLite is enough for launch testing; production can move to PostgreSQL later.
DATABASE_URL="file:./dev.db"

# i18n
NUXT_PUBLIC_SITE_URL=https://tradervote.com
NUXT_PUBLIC_BASE_URL=https://tradervote.com

# Google OAuth login
# Authorized redirect URI in Google Cloud:
# https://tradervote.com/api/auth/google/callback
# Development redirect URI:
# https://dev.tradervote.com/api/auth/google/callback
GOOGLE_CLIENT_ID=change-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=https://tradervote.com/api/auth/google/callback

# Optional: revalidate webhook secret (AI workers -> Nuxt ISR refresh)
NUXT_REVALIDATE_SECRET=change-me

# Zoho Mail SMTP
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@tradervote.com
SMTP_PASSWORD=change-me
SMTP_FROM="TraderVote <info@tradervote.com>"
SMTP_REPLY_TO=support@tradervote.com
