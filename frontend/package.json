{
  "name": "tradervote-frontend",
  "version": "2.0.0",
  "private": true,
  "description": "Tradervote v2 — Nuxt 3 SSR + i18n (EN/TH/VI/ID) + Trust Score",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 0.0.0.0 --port 3001",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.5.7",
    "@nuxtjs/i18n": "^9.1.1",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "eslint": "^9.17.0",
    "nuxt": "^3.15.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.2.0"
  },
  "dependencies": {
    "@nuxt/image": "^1.10.0",
    "@pinia/nuxt": "^0.7.0",
    "@prisma/client": "^6.19.0",
    "@vueuse/core": "^12.0.0",
    "@vueuse/nuxt": "^12.0.0",
    "flag-icons": "^7.5.0",
    "nodemailer": "^9.0.3",
    "pinia": "^2.3.0",
    "prisma": "^6.19.0",
    "vue": "^3.5.13"
  }
}
